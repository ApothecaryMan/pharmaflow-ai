{
  "name": "zinc",
  "description": "Comprehensive pharmacy management system with AI-powered features, POS, inventory tracking, and bilingual support (EN/AR)",
  "author": "ZINC Team",
  "license": "UNLICENSED",
  "private": true,
  "version": "2.013",
  "type": "module",
  "keywords": [
    "pharmacy",
    "pos",
    "inventory",
    "sales",
    "management",
    "react",
    "typescript",
    "rtl",
    "bilingual"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ApothecaryMan/pharmaflow-ai"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "check-translations": "ts-node scripts/check-translations.ts",
    "type-check": "tsc --noEmit",
    "supabase:generate": "supabase gen types typescript --project-id \"$SUPABASE_PROJECT_ID\" > src/types/supabase.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/geist": "^5.2.8",
    "@google/genai": "^1.30.0",
    "@mynaui/icons-react": "^0.4.2",
    "@simplewebauthn/browser": "^13.2.2",
    "@supabase/supabase-js": "^2.99.3",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.18",
    "barcode-detector": "^3.1.0",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "idb": "^8.0.3",
    "maplibre-gl": "^5.19.0",
    "motion": "^12.38.0",
    "qrcode": "^1.5.3",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.0",
    "react-hotkeys-hook": "^5.2.4",
    "recharts": "^3.5.1",
    "shadcn": "^4.0.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@letuscode/spec-kit": "^0.1.3",
    "@netlify/functions": "^5.1.2",
    "@tailwindcss/postcss": "^4.2.0",
    "@tailwindcss/vite": "^4.2.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.0.17",
    "autoprefixer": "^10.4.24",
    "globals": "^17.3.0",
    "jsdom": "^27.4.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.0.17"
  }
}

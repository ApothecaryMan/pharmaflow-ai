{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ZINC",
  "version": "2.023",
  "identifier": "com.zinc.pharmacy",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "title": "ZINC - نظام إدارة الصيدليات",
    "windows": [
      {
        "title": "ZINC",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "tooltip": "ZINC - نظام إدارة الصيدليات",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "compression": "lzma",
        "installMode": "currentUser",
        "displayLanguageSelector": true,
        "languages": ["Arabic", "English"]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ApothecaryMan/pharmaflow-ai/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  }
}
